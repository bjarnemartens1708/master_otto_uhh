{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/communication/**",
              "components/containers/**",
              "components/feedback/**",
              "components/forms/**",
              "components/icons/**",
              "components/navigation/**",
              "components/overlays/**",
              "ui_kits/otto_app/**",
              "ui_kits/otto_web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Accordion'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|defaultOpen|children|style|key|ref|className|style|children)$/]",
        "message": "<Accordion> doesn't accept that prop. Declared props: title, defaultOpen, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActionSignifier'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|iconOnly|inverted|style|key|ref|className|style|children)$/]",
        "message": "<ActionSignifier> doesn't accept that prop. Declared props: label, iconOnly, inverted, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|max|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, size, icon, max, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|info|success|error|warning|hint)$/]",
        "message": "<Badge> variant must be one of 'primary' | 'secondary' | 'info' | 'success' | 'error' | 'warning' | 'hint'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:semantic|size|headline|action|onAction|onClose|children|style|key|ref|className|style|children)$/]",
