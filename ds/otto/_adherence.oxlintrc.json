        "selector": "JSXOpeningElement[name.name='Block'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|dark|padding|children|style|key|ref|className|style|children)$/]",
        "message": "<Block> doesn't accept that prop. Declared props: color, dark, padding, children, style."
