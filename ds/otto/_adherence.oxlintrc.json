        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='semantic'] > Literal[value!=/^(?:info|hint|success|warning|error)$/]",
        "message": "<Banner> semantic must be one of 'info' | 'hint' | 'success' | 'warning' | 'error'."
